datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Student {
  id    Int    @id @default(autoincrement())
  name  String
  assignments Assignment[]
  helpedAssignments Assignment[] @relation("Helper")
}

model Week {
  id        Int      @id @default(autoincrement())
  startDate DateTime @unique

  assignments Assignment[]
}

model Assignment {
  id          Int      @id @default(autoincrement())
  type        String
  title       String
  duration    Int

  studentId   Int
  helperId    Int?
  weekId      Int

  student     Student  @relation("StudentAssignments", fields: [studentId], references: [id])
  helper      Student? @relation("HelperAssignments", fields: [helperId], references: [id])

  week        Week     @relation(fields: [weekId], references: [id], onDelete: Cascade) // 🔥 AQUI
}