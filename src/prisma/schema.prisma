generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Student {
  id     Int     @id @default(autoincrement())
  name   String
  gender String? // 👈 opcional por enquanto

  // 🔥 RELAÇÕES (OBRIGATÓRIO)
  assignments       Assignment[] @relation("StudentAssignments")
  helpedAssignments Assignment[] @relation("HelperAssignments")
}

model Week {
  id               Int      @id @default(autoincrement())
  startDate        DateTime
  hasDemonstration Boolean  @default(false)

  assignments Assignment[]
}

model Assignment {
  id       Int    @id @default(autoincrement())
  type     String
  title    String
  duration Int

  studentId Int
  helperId  Int?
  weekId    Int

  // 🔥 NOVOS CAMPOS (dashboard inteligente)
  declined           Boolean @default(false)
  declineReason      String?
  needsEncouragement Boolean @default(false)
  encouragementNote  String?

  // 🔥 RELAÇÕES NOMEADAS (AGORA CORRETAS)
  student Student  @relation("StudentAssignments", fields: [studentId], references: [id], onDelete: Cascade)
  helper  Student? @relation("HelperAssignments", fields: [helperId], references: [id], onDelete: SetNull)

  week Week @relation(fields: [weekId], references: [id], onDelete: Cascade)
}
